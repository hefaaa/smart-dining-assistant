generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TableSession {
  id         String   @id @default(cuid())
  tableId    String
  createdAt  DateTime @default(now())
  expiresAt  DateTime
}

model CartItem {
  id           String @id @default(cuid())

  tableId      String

  itemId       String
  itemName     String

  quantity     Int

  instructions String?
}

model Order {
  id           String   @id @default(cuid())

  tableId      String

  customerName String
  phone        String

  total        Float

  status       String

  createdAt    DateTime @default(now())
}